# OpenAI
OPENAI_API_KEY=sk-...

# Supabase (server-side only — use service role, not publishable key, in backend)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional: direct Postgres connection (migrations, raw SQL)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# App
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated origins allowed by CORS (no trailing slash)
CORS_ORIGINS=http://localhost:3000

# Models
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_TTS_VOICE=verse

# Retrieval
CHUNK_SIZE_TOKENS=600
CHUNK_OVERLAP_TOKENS=80
RETRIEVAL_TOP_K=12

# Upload limits
MAX_UPLOAD_FILES=20
MAX_FILE_SIZE_MB=2
MAX_AUDIO_SIZE_MB=25
